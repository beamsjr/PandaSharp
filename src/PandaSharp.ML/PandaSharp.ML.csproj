<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>PandaSharp.ML</RootNamespace>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <PackageId>PandaSharp.ML</PackageId>
    <Description>Machine learning toolkit for PandaSharp: tensors, feature engineering, pipelines, evaluation</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageTags>ml;machine-learning;dataframe;tensor;pipeline;feature-engineering</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="PandaSharp.ML.Tests" />
    <InternalsVisibleTo Include="PandaSharp.Viz" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\PandaSharp\PandaSharp.csproj" />
  </ItemGroup>

</Project>
