<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <RootNamespace>PandaSharp.GPU</RootNamespace>
    <PackageId>PandaSharp.GPU</PackageId>
    <Description>GPU-accelerated operations for PandaSharp using ILGPU. Supports CUDA, OpenCL, and CPU fallback.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\PandaSharp\PandaSharp.csproj" />
    <ProjectReference Include="..\PandaSharp.ML\PandaSharp.ML.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="ILGPU" Version="1.*" />
    <PackageReference Include="ILGPU.Algorithms" Version="1.*" />
  </ItemGroup>
</Project>
