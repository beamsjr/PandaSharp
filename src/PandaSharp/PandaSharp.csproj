<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>PandaSharp</RootNamespace>
    <PackageId>PandaSharp</PackageId>
    <Description>A high-performance, pandas-like DataFrame library for .NET</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageTags>dataframe;data;analytics;arrow;columnar</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="PandaSharp.ML" />
    <InternalsVisibleTo Include="PandaSharp.Tests.Unit" />
    <InternalsVisibleTo Include="PandaSharp.ML.Tests" />
    <InternalsVisibleTo Include="PandaSharp.IO.Database" />
    <InternalsVisibleTo Include="ComprehensiveBench" />
  </ItemGroup>

  <!-- Native C accelerators -->
  <ItemGroup>
    <None Include="Native/libpandasharp.dylib" CopyToOutputDirectory="PreserveNewest" Pack="true" PackagePath="runtimes/osx-arm64/native" Condition="Exists('Native/libpandasharp.dylib')" />
    <None Include="Native/libpandasharp.so" CopyToOutputDirectory="PreserveNewest" Pack="true" PackagePath="runtimes/linux-x64/native" Condition="Exists('Native/libpandasharp.so')" />
    <None Include="Native/libpandasharp_quantile.dylib" CopyToOutputDirectory="PreserveNewest" Pack="true" PackagePath="runtimes/osx-arm64/native" Condition="Exists('Native/libpandasharp_quantile.dylib')" />
    <None Include="Native/libpandasharp_quantile.so" CopyToOutputDirectory="PreserveNewest" Pack="true" PackagePath="runtimes/linux-x64/native" Condition="Exists('Native/libpandasharp_quantile.so')" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="AngleSharp" Version="1.4.0" />
    <PackageReference Include="Apache.Arrow" Version="18.*" />
    <PackageReference Include="ClosedXML" Version="0.105.0" />
    <PackageReference Include="Parquet.Net" Version="5.5.0" />
  </ItemGroup>

</Project>
