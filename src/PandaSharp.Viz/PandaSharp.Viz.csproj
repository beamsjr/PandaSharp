<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>PandaSharp.Viz</RootNamespace>
    <PackageId>PandaSharp.Viz</PackageId>
    <Description>Interactive D3.js visualizations for PandaSharp DataFrames</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageTags>visualization;charts;d3;dataframe;interactive</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\PandaSharp\PandaSharp.csproj" />
    <ProjectReference Include="..\PandaSharp.ML\PandaSharp.ML.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="PuppeteerSharp" Version="24.40.0" />
  </ItemGroup>

</Project>
