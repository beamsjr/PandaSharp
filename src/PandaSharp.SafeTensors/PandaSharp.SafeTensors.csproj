<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <RootNamespace>PandaSharp.SafeTensors</RootNamespace>
    <PackageId>PandaSharp.SafeTensors</PackageId>
    <Description>HuggingFace SafeTensors format reader/writer for PandaSharp: memory-mapped tensor loading, zero-copy access</Description>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\PandaSharp.ML\PandaSharp.ML.csproj" />
  </ItemGroup>
</Project>
