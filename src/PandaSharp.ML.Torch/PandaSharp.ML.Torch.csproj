<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>PandaSharp.ML.Torch</RootNamespace>
    <PackageId>PandaSharp.ML.Torch</PackageId>
    <Description>TorchSharp tensor bridge for PandaSharp DataFrames</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\PandaSharp\PandaSharp.csproj" />
    <ProjectReference Include="..\PandaSharp.ML\PandaSharp.ML.csproj" />
    <ProjectReference Include="..\PandaSharp.SafeTensors\PandaSharp.SafeTensors.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="TorchSharp" Version="0.103.*" />
  </ItemGroup>

</Project>
