<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>PandaSharp.Vision</RootNamespace>
    <PackageId>PandaSharp.Vision</PackageId>
    <Description>Image and video processing for PandaSharp: transforms, augmentation pipelines, data loaders, and model integration</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageTags>image;vision;augmentation;dataframe;tensor;computer-vision</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\PandaSharp\PandaSharp.csproj" />
    <ProjectReference Include="..\PandaSharp.ML\PandaSharp.ML.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="SixLabors.ImageSharp" Version="3.*" />
    <PackageReference Include="FFMediaToolkit" Version="4.*" />
    <PackageReference Include="Microsoft.ML.OnnxRuntime" Version="1.*" />
  </ItemGroup>

  <!-- Native video decoder -->
  <ItemGroup>
    <None Include="Native/libpandavision.dylib" CopyToOutputDirectory="PreserveNewest" Condition="Exists('Native/libpandavision.dylib')" />
    <None Include="Native/libpandavision.so" CopyToOutputDirectory="PreserveNewest" Condition="Exists('Native/libpandavision.so')" />
    <None Include="Native/libpandavision_apple.dylib" CopyToOutputDirectory="PreserveNewest" Condition="Exists('Native/libpandavision_apple.dylib')" />
  </ItemGroup>

</Project>
